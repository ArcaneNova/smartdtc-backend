# SmartDTC Backend — Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/smartdtc

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# AI Microservice (Python FastAPI)
PYTHON_AI_URL=https://ai-service-4hzt.onrender.com
AI_SERVICE_URL=https://ai-service-4hzt.onrender.com
